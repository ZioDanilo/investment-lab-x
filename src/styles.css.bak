:root{color-scheme:dark;font-family:Inter,Segoe UI,Arial,sans-serif;--bg:#050816;--panel:rgba(10,16,32,.78);--panel-strong:rgba(15,24,46,.95);--border:rgba(255,255,255,.14);--text:#f4f7ff;--muted:#95a7c7;--accent:#7c5cff;--accent-2:#18d5ff;--accent-3:#ff5bd1}*{box-sizing:border-box}html,body{height:100%}body{margin:0;background:radial-gradient(circle at top left,#1a2147 0%,#070b16 45%,#03050b 100%);color:var(--text)}body::before{content:"";position:fixed;inset:0;pointer-events:none;background-image:radial-gradient(rgba(255,255,255,.08) 0.8px,transparent 0),radial-gradient(rgba(24,213,255,.08) 0.9px,transparent 0),radial-gradient(rgba(124,92,255,.06) 1px,transparent 0);background-size:18px 18px,32px 32px,48px 48px;opacity:.55;mix-blend-mode:screen;animation:particleDrift 12s linear infinite}button,input,select{font:inherit}app-root{display:block;height:100%}.app-shell{min-height:100vh;display:grid;grid-template-columns:280px 1fr;background:linear-gradient(120deg,rgba(255,255,255,.06),transparent 38%)}@media(max-width:1024px){.app-shell{grid-template-columns:240px 1fr}}@media(max-width:768px){.app-shell{grid-template-columns:1fr;min-height:100vh}}@media(max-width:768px){.sidebar{padding:16px 14px;gap:16px}}.sidebar{position:relative;padding:24px 18px;display:flex;flex-direction:column;gap:24px;background:linear-gradient(160deg,rgba(7,11,24,.96),rgba(16,24,46,.8));backdrop-filter:blur(26px);border-right:1px solid var(--border);overflow:hidden}@media(max-width:768px){.sidebar{position:fixed;left:0;top:0;width:100%;height:auto;flex-direction:row;align-items:center;justify-content:space-between;border-right:none;border-bottom:1px solid var(--border);z-index:100}}@media(max-width:768px){.nav-main{display:none}}.nav-main{position:relative;display:flex;flex-direction:column;gap:10px;z-index:1}@media(max-width:1024px){.brand-block h1{font-size:.95rem}}@media(max-width:768px){.brand-block{gap:8px}.brand-mark{width:40px;height:40px}.brand-block h1{font-size:.9rem}.brand-block p{font-size:.75rem}}.page-panel{display:flex;flex-direction:column;gap:14px;padding:16px}@media(max-width:768px){.page-panel{gap:10px;padding:12px 12px}}.page-header{display:flex;flex-direction:column;gap:6px;margin-bottom:6px}@media(max-width:768px){.page-header h2{font-size:1.3rem}.page-header p{font-size:.85rem}}.page-header h2{margin:0;font-size:1.6rem;color:#f7fbff}.page-header p{margin:0;color:var(--muted)}.content-card{padding:16px;border-radius:18px;background:linear-gradient(135deg,rgba(9,15,31,.9),rgba(10,15,30,.8));border:1px solid rgba(255,255,255,.08);overflow:hidden}@media(max-width:768px){.content-card{padding:12px;border-radius:14px}}gap:10px;z-index:1}.nav-spacer{flex:1}.nav-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border:1px solid transparent;border-radius:16px;background:rgba(255,255,255,.03);color:var(--text);text-align:left;cursor:pointer;transition:all .22s ease;box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}.nav-item:hover{transform:translateX(2px);border-color:rgba(24,213,255,.4);background:linear-gradient(90deg,rgba(24,213,255,.16),rgba(124,92,255,.16));box-shadow:0 0 26px rgba(24,213,255,.12)}.nav-item.active{background:linear-gradient(90deg,rgba(124,92,255,.28),rgba(24,213,255,.18));border-color:rgba(255,255,255,.2);box-shadow:0 0 30px rgba(124,92,255,.24)}.icon{display:grid;place-items:center;width:38px;height:38px;border-radius:12px;background:linear-gradient(135deg,rgba(255,255,255,.16),rgba(255,255,255,.05));font-size:1.1rem}.copy{display:flex;flex-direction:column;gap:2px}.copy strong{font-size:.95rem}.copy small{font-size:.76rem;color:var(--muted)}.sidebar-footer{position:relative;margin-top:auto;padding:14px;border-radius:16px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);color:var(--muted);font-size:.84rem;z-index:1}.sidebar-footer p{margin:0 0 4px;color:var(--text)}.content-area{padding:24px;display:flex;flex-direction:column;gap:18px}.topbar{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:18px 24px;border-radius:24px;background:linear-gradient(120deg,rgba(12,19,38,.92),rgba(18,28,54,.76));border:1px solid var(--border);box-shadow:0 14px 44px rgba(4,7,18,.3)}.eyebrow{font-size:.82rem;letter-spacing:.24em;text-transform:uppercase;color:#8ddcff}.topbar h2{margin:6px 0 0;font-size:2rem}.content-card{padding:16px;border-radius:18px;background:linear-gradient(135deg,rgba(9,15,31,.9),rgba(10,15,30,.8));border:1px solid rgba(255,255,255,.08);overflow:hidden}.content-card::before,.content-card::after{content:"";position:absolute;inset:0;pointer-events:none;mix-blend-mode:screen;opacity:.72}.content-card::before{background:radial-gradient(circle at 12% 20%,rgba(255,255,255,.55) 0 2px,transparent 2.6px),radial-gradient(circle at 24% 32%,rgba(24,213,255,.6) 0 2px,transparent 2.6px),radial-gradient(circle at 36% 18%,rgba(124,92,255,.7) 0 2px,transparent 2.6px),radial-gradient(circle at 52% 25%,rgba(255,255,255,.55) 0 1.8px,transparent 2.4px),radial-gradient(circle at 70% 33%,rgba(24,213,255,.65) 0 2px,transparent 2.6px),radial-gradient(circle at 82% 20%,rgba(124,92,255,.62) 0 2px,transparent 2.6px),radial-gradient(circle at 90% 40%,rgba(255,255,255,.55) 0 1.8px,transparent 2.4px),radial-gradient(circle at 40% 60%,rgba(255,255,255,.5) 0 1.6px,transparent 2.2px),radial-gradient(circle at 85% 15%,rgba(24,213,255,.35) 0 1.8px,transparent 2.4px);background-size:180% 180%;animation:particleDrift 8s linear infinite}.content-card::after{background:radial-gradient(circle at 12% 70%,rgba(124,92,255,.55) 0 2px,transparent 2.6px),radial-gradient(circle at 24% 82%,rgba(255,255,255,.6) 0 1.8px,transparent 2.4px),radial-gradient(circle at 38% 73%,rgba(24,213,255,.7) 0 2px,transparent 2.6px),radial-gradient(circle at 52% 66%,rgba(124,92,255,.58) 0 2px,transparent 2.6px),radial-gradient(circle at 66% 82%,rgba(255,255,255,.55) 0 1.8px,transparent 2.4px),radial-gradient(circle at 78% 70%,rgba(24,213,255,.6) 0 2px,transparent 2.6px),radial-gradient(circle at 86% 56%,rgba(255,255,255,.48) 0 1.8px,transparent 2.4px),radial-gradient(circle at 92% 42%,rgba(124,92,255,.44) 0 2px,transparent 2.6px),radial-gradient(circle at 68% 40%,rgba(255,255,255,.35) 0 1.6px,transparent 2.2px);background-size:180% 180%;animation:particleDrift 10s linear infinite reverse;opacity:.55}.body-dots::before{content:"";position:fixed;inset:0;pointer-events:none;background-image:radial-gradient(rgba(255,255,255,.06) 0.8px,transparent 0),radial-gradient(rgba(24,213,255,.06) 0.9px,transparent 0),radial-gradient(rgba(124,92,255,.06) 1px,transparent 0);background-size:18px 18px,32px 32px,48px 48px;opacity:.55;mix-blend-mode:screen;animation:particleDrift 12s linear infinite}.table-shell{position:relative;z-index:1;overflow:auto;border-radius:20px;border:1px solid rgba(255,255,255,.1);background:rgba(2,8,23,.56);backdrop-filter:blur(12px)}.kpi-table{width:100%;border-collapse:collapse;min-width:720px}.kpi-table th,.kpi-table td{padding:12px 14px;text-align:left;border-bottom:1px solid rgba(255,255,255,.08)}.kpi-table th{background:rgba(255,255,255,.06);font-size:.85rem;text-transform:uppercase;letter-spacing:.16em;color:#c7d6ff}.kpi-table td{color:var(--text)}.field-select,.field-input{width:100%;padding:10px 12px;border-radius:12px;border:1px solid rgba(255,255,255,.16);background:rgba(8,12,20,.98);color:#fff;box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}.field-select:hover,.field-input:hover{background:rgba(22,32,52,1);transform:translateY(-1px)}.field-select{appearance:none;background-image:linear-gradient(45deg,transparent 50%,rgba(255,255,255,.8) 50%),linear-gradient(135deg,rgba(255,255,255,.8) 50%,transparent 50%);background-position:calc(100% - 18px) calc(1em + 2px),calc(100% - 12px) calc(1em + 2px);background-size:6px 6px,6px 6px;background-repeat:no-repeat}.field-select:disabled,.field-input:disabled{opacity:.55;cursor:not-allowed}.field-input.invalid{border-color:#ff7aa2;box-shadow:0 0 0 1px rgba(255,122,162,.25)}.portfolio-cell{padding:8px 10px;border-radius:999px;background:linear-gradient(90deg,rgba(124,92,255,.24),rgba(24,213,255,.2));display:inline-block;color:#eff7ff}.page-header-actions{display:flex;align-items:flex-start;justify-content:space-between;gap:20px}.btn{border:none;padding:10px 18px;border-radius:14px;font-weight:600;cursor:pointer;transition:transform .16s ease,box-shadow .16s ease}.btn:hover{transform:translateY(-1px)}.btn-secondary{background:linear-gradient(135deg,#2d3a5e,#1d2541);color:#fff;box-shadow:0 12px 32px rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.08)}.card-soft{padding:20px;border-radius:22px;background:rgba(6,12,22,.95);border:1px solid rgba(255,255,255,.08);box-shadow:0 20px 60px rgba(0,0,0,.18);backdrop-filter:blur(12px)}.card-title{font-size:1rem;text-transform:uppercase;letter-spacing:.18em;color:#8bc8ff;margin-bottom:16px}.kpi-summary-table{width:100%;border-collapse:collapse}.kpi-summary-table th,.kpi-summary-table td{padding:12px 14px;text-align:left;border-bottom:1px solid rgba(255,255,255,.08)}.kpi-summary-table th{background:rgba(255,255,255,.05);font-size:.82rem;color:#c7d6ff}.kpi-summary-table td{color:var(--text)}.summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px}.summary-item{padding:16px;border-radius:18px;background:linear-gradient(180deg,rgba(20,34,58,.98),rgba(12,19,35,.92));border:1px solid rgba(255,255,255,.08)}.summary-item span{display:block;color:var(--muted);text-transform:uppercase;letter-spacing:.14em;font-size:.78rem;margin-bottom:8px}.summary-item strong{display:block;font-size:1.4rem;color:#fff}.score-table th, .score-table td{font-size:.82rem}.score-good{background:rgba(30,107,86,.18)}.score-neutral{background:rgba(118,98,51,.15)}.score-low{background:rgba(123,26,35,.18)}.score-table td{transition:background .2s ease}.weight-input:focus{outline:none;box-shadow:0 0 0 2px rgba(28,184,255,.28)}
.page-panel{display:flex;flex-direction:column;gap:10px;padding:12px}@media(max-width:768px){.page-panel{gap:8px;padding:10px}}.page-header-compact{padding-bottom:4px;border-bottom:1px solid rgba(255,255,255,.08)}.page-header h2{margin:0;font-size:1.6rem;color:#f7fbff}.page-header p{margin:0;color:var(--muted)}.summary-card{display:flex;flex-direction:column;gap:6px;padding:18px;border-radius:20px;background:rgba(8,12,20,.92);border:1px solid rgba(255,255,255,.08);min-width:180px}.summary-card span{color:var(--muted);font-size:.82rem;text-transform:uppercase;letter-spacing:.18em}.summary-card strong{font-size:1.75rem;color:#fff}.summary-card.invalid{border-color:#ff5d7f;box-shadow:0 0 0 1px rgba(255,93,127,.18)}.delta-card strong.positive{color:#4dffaa}.delta-card strong.negative{color:#ff7a88}.portfolio-table{width:100%;border-collapse:collapse;min-width:640px;font-size:.85rem}@media(max-width:768px){.portfolio-table{font-size:.8rem}}.portfolio-table th,.portfolio-table td{padding:8px 10px;text-align:left;border-bottom:1px solid rgba(255,255,255,.06)}@media(max-width:768px){.portfolio-table th,.portfolio-table td{padding:6px 8px}}.portfolio-table th{background:rgba(255,255,255,.03);font-size:.75rem;text-transform:uppercase;letter-spacing:.15em;color:#a8b8ff}.portfolio-table td{color:var(--text)}.portfolio-table .num{font-feature-settings:'tnum';text-align:right}.weight-input{width:100%;padding:6px 8px;border-radius:8px;border:1px solid rgba(255,255,255,.14);background:rgba(8,12,20,.95);color:#fff;font-size:.85rem}.weight-input:focus{outline:none;box-shadow:0 0 0 1px rgba(28,184,255,.2)}.correlation-shell{overflow:auto}.correlation-table{width:100%;border-collapse:collapse;min-width:780px}.correlation-table th,.correlation-table td{padding:10px 12px;text-align:center;border:1px solid rgba(255,255,255,.08)}.correlation-table th{background:rgba(255,255,255,.06);color:#c7d6ff;font-size:.75rem;text-transform:uppercase;letter-spacing:.18em}.correlation-table td{color:#fff;font-size:.82rem}.corr-positive{background:linear-gradient(180deg,rgba(18,92,66,.96),rgba(41,126,90,.92));color:#e8fff1;border:1px solid rgba(80,255,181,.16)}.corr-neutral{background:linear-gradient(180deg,rgba(85,78,61,.96),rgba(121,107,86,.92));color:#f7f2d8;border:1px solid rgba(255,221,118,.16)}.corr-negative{background:linear-gradient(180deg,rgba(124,33,41,.96),rgba(154,56,63,.92));color:#ffd7d8;border:1px solid rgba(255,131,135,.18)}.placeholder-panel{padding:0}.placeholder-card{padding:28px;border-radius:24px;background:rgba(11,17,34,.9);border:1px solid rgba(255,255,255,.08);color:var(--muted)}

@keyframes particleDrift{0%{background-position:0 0;opacity:.2}25%{background-position:40% 10%;opacity:.5}50%{background-position:100% 50%;opacity:.7}75%{background-position:60% 100%;opacity:.35}100%{background-position:0 0;opacity:.2}}


